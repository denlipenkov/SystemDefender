{
  "name": "system-defender",
  "version": "1.2.0",
  "description": "System Defender: Cyber Warfare — tower defense shooter",
  "main": "main.js",
  "scripts": {
    "analyze-music": "node tools/analyze-music-segments.mjs",
    "start": "electron .",
    "start:dev": "electron . --dev",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux"
  },
  "build": {
    "appId": "com.systemdefender.app",
    "productName": "System Defender",
    "copyright": "Copyright © 2026",
    "files": [
      "src/**/*",
      "assets/**/*",
      "main.js",
      "preload.js",
      "node_modules/pixi.js/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Game"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    }
  },
  "dependencies": {
    "pixi.js": "^8.6.6"
  },
  "devDependencies": {
    "audio-decode": "^2.2.3",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  }
}
